# Normalize line endings: store as LF, checkout as native
* text=auto

# Force LF for all code and config files
*.py    text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.txt   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.env   text eol=lf

# Binary files — no line-ending conversion
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.zip   binary
