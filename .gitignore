# ── Project-specific generated files ──────────────────────────────────────────
# Scaffolded per target application via `framework init-project`.
# Never commit these to the shared framework repo — each client keeps their own
# fork/branch/directory for their project files.
locators/[!_]*.py
pages/[!_]*.py
tests/workflows/test_*.py
tests/api/test_*.py
stories/*.json

# ── Framework runtime artefacts ───────────────────────────────────────────────
memory/framework_memory.json
memory/*.lock
reports/report.html
reports/screenshots/
reports/videos/

# ── Allure ────────────────────────────────────────────────────────────────────
allure-results/
allure-report/

# ── Bug reports (generated by reporter loop) ──────────────────────────────────
bugs.md

# Playwright
playwright-report/
test-results/

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
